  "devDependencies": {
    "@remotion/cli": "^4.0.451",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "remotion": "^4.0.451",
    "typescript": "^6.0.3"
  }
